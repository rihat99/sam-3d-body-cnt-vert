# Training configuration for Contact Head

# Model Configuration
MODEL:
  # Checkpoint path - UPDATE THIS PATH to your SAM-3D-Body checkpoint
  CHECKPOINT_PATH: "/home/rikhat/human_global_motion/sam-3d-body/checkpoints/sam-3d-body-dinov3/model.ckpt"  # CHANGE ME
  MHR_MODEL_PATH: "/home/rikhat/human_global_motion/sam-3d-body/checkpoints/sam-3d-body-dinov3/assets/mhr_model.pt"  # CHANGE ME
  
  # Image settings
  IMAGE_SIZE: [256, 192]
  IMAGE_MEAN: [0.485, 0.456, 0.406]
  IMAGE_STD: [0.229, 0.224, 0.225]
  
  # Backbone settings
  BACKBONE:
    TYPE: "vit_hmr"
    FROZEN: true
  
  # Decoder settings
  DECODER:
    DIM: 1024
    FROZEN: true
    DO_CONTACT_TOKENS: true
    DO_KEYPOINT_TOKENS: true
    DO_KEYPOINT3D_TOKENS: true
    CONDITION_TYPE: "cliff"
    USE_INTRIN_CENTER: false
  
  # Contact Head settings
  CONTACT_HEAD:
    NUM_CONTACTS: 4  # left_hand, right_hand, left_foot, right_foot
    MLP_DEPTH: 2
    MLP_CHANNEL_DIV_FACTOR: 4
  
  # Prompt Encoder settings
  PROMPT_ENCODER:
    ENABLE: true
    MAX_NUM_CLICKS: 1
    PROMPT_KEYPOINTS: "mhr70"
    MASK_EMBED_TYPE: null
  
  # MHR Head settings
  MHR_HEAD:
    MHR_MODEL_PATH: ""  # Will be set from MHR_MODEL_PATH above
    MLP_DEPTH: 1
    MLP_CHANNEL_DIV_FACTOR: 1
  
  # Person Head settings
  PERSON_HEAD:
    POSE_TYPE: "mhr"
    CAMERA_TYPE: "perspective"
  
  # Camera Head settings
  CAMERA_HEAD:
    MLP_DEPTH: 1
    MLP_CHANNEL_DIV_FACTOR: 1
    DEFAULT_SCALE_FACTOR: 1.0

# Training Configuration
TRAIN:
  # Batch size (adjust for your GPU - 4090 with 24GB should handle 16-32)
  # Starting with smaller batches for initial testing
  BATCH_SIZE: 8
  VAL_BATCH_SIZE: 4
  
  # Number of workers for data loading
  NUM_WORKERS: 4
  
  # Training epochs
  # Start with fewer epochs for testing, increase later
  EPOCHS: 20
  
  # Learning rate
  LR: 1e-4
  
  # Weight decay
  WEIGHT_DECAY: 1e-4
  
  # Learning rate schedule
  LR_SCHEDULER: "cosine"  # "cosine" or "step"
  LR_WARMUP_EPOCHS: 5
  LR_MIN: 1e-6
  
  # Mixed precision training
  USE_FP16: true
  FP16_TYPE: "float16"
  
  # Gradient clipping
  GRAD_CLIP: 1.0
  
  # Loss weights (for different contact types)
  LOSS_WEIGHTS:
    hand: 1.0  # Weight for hand contact loss
    foot: 1.0  # Weight for foot contact loss
  
  # Class weights for imbalanced data (contact vs no-contact)
  # Will be computed from dataset if set to null
  POS_WEIGHT: null
  
  # Save checkpoints every N epochs
  SAVE_FREQ: 5
  
  # Validation frequency (every N epochs)
  VAL_FREQ: 1
  
  # Resume from checkpoint
  RESUME: null

# Dataset Configuration
DATASET:
  # Path to ETH dataset
  DATA_PATH: "/home/rikhat/climbing/climb_forces/data/eth"
  
  # Which folders to use for training/validation
  TRAIN_FOLDERS: ["1"]  # Start with folder 1 for testing
  VAL_FOLDERS: []  # Will use split from train folders if empty
  
  # Which camera sides to use
  SIDES: ["left"]  # Start with left only for testing
  
  # Train/val split ratio (if VAL_FOLDERS is empty)
  TRAIN_VAL_SPLIT: 0.8
  
  # Contact threshold in Newtons
  CONTACT_THRESHOLD: 50
  
  # Random seed for reproducibility
  SEED: 42
  
  # Cache settings
  USE_CACHE: true
  REBUILD_CACHE: false

# Output Configuration
OUTPUT:
  # Output directory for checkpoints and logs
  DIR: "./train/output"
  
  # Experiment name
  EXP_NAME: "contact_head_eth"
  
  # Logging
  LOG_FREQ: 10  # Log every N iterations
  
  # Tensorboard
  USE_TENSORBOARD: true

# ETH Camera Parameters (same for all images in dataset)
CAMERA:
  # Camera intrinsics matrix
  # fx, 0,  cx
  # 0,  fy, cy
  # 0,  0,  1
  fx: 1419.27383
  fy: 1419.21058
  cx: 966.397807
  cy: 498.565941
  
  # Distortion coefficients (not used in training but stored for reference)
  dist: [0.03452283, -0.18056709, -0.00329048, -0.00233279, 0.13364379]
